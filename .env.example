# ClaimPilot — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to GitHub — only .env.example is committed

# ─────────────────────────────────────────
# Groq API (free tier at console.groq.com)
# ─────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ─────────────────────────────────────────
# PostgreSQL (local installation)
# ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=claimpilot
POSTGRES_USER=your_postgres_username
POSTGRES_PASSWORD=your_postgres_password

# ─────────────────────────────────────────
# ChromaDB (local persistence)
# ─────────────────────────────────────────
CHROMA_PERSIST_PATH=./chroma_store

# ─────────────────────────────────────────
# Tesseract OCR
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac: /usr/bin/tesseract
# ─────────────────────────────────────────
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ─────────────────────────────────────────
# Embeddings (local — no API key needed)
# ─────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─────────────────────────────────────────
# FastAPI
# ─────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your_secret_key_for_session_tokens

# ─────────────────────────────────────────
# Chunking Configuration
# ─────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ─────────────────────────────────────────
# Agent Configuration
# ─────────────────────────────────────────
INTENT_CONFIDENCE_THRESHOLD=0.75
QUERY_ROUTER_CONFIDENCE_THRESHOLD=0.75
